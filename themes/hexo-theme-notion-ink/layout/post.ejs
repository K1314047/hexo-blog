<article class="article-page container">
  <header class="article-header">
    <h1><%= page.title %></h1>
    <p class="article-meta">发布于 <%= date(page.date, 'YYYY-MM-DD') %> · 更新于 <%= date(page.updated || page.date, 'YYYY-MM-DD') %></p>
  </header>
  <div class="article-content"><%- page.content %></div>
</article>
